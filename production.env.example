# Production Environment Configuration Template
# Copy this file to .env and update the values

NODE_ENV=production
PORT=3001

# Database Configuration
DB_HOST=localhost
DB_NAME=axumpulse_prod
DB_USER=axumpulse_user
DB_PASS=your_secure_password_here
DB_DIALECT=mysql

# sample data for dev login
DEV_ADMIN_PHONE=251911000000
DEV_ADMIN_PASSWORD=adminpass
DEV_TRAINER_PHONE=251911000001
DEV_TRAINER_PASSWORD=trainerpass
DEV_USER_PHONE=251911000002
DEV_USER_PASSWORD=userpass
DEV_MEDICAL_PHONE=251911000003
DEV_MEDICAL_PASSWORD=medicalpass

# JWT Configuration
JWT_SECRET=your_very_secure_jwt_secret_key_here_make_it_long_and_random

# Ethiotell 6313: POST /api/v1/integrations/ethiotell/subscribe (JSON body), POST .../unsubscribe (phone_number)
# Optional legacy HMAC (disabled unless middleware re-enabled): ETHIOTELL_WEBHOOK_SECRET, X-Ethiotell-Signature
ETHIOTELL_WEBHOOK_SECRET=change_me_long_random_secret
# Optional comma-separated IP allowlist (only if legacy HMAC middleware is restored)
# ETHIOTELL_WEBHOOK_IPS=203.0.113.10,198.51.100.0

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=50MB

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_here

# Email Configuration (if using email features)
EMAIL_HOST=smtp.yourdomain.com
EMAIL_PORT=587
EMAIL_USER=noreply@yourdomain.com
EMAIL_PASS=your_email_password

# Admin Configuration
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your_secure_admin_password

# Gemini AI Configuration (for medical triage)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
# Options: gemini-1.5-flash (faster, cheaper) or gemini-1.5-pro (more nuanced)

CHAPA_SECRET_KEY=
CHAPA_PUBLIC_KEY=
CHAPA_WEBHOOK_SECRET=

# Public origin for Chapa return_url / callback_url (scheme + host + port).
# You may include /api/v1; it is normalized so paths are not doubled — final URLs are always .../api/v1/payments/...
# Dev on LAN: http://192.168.x.x:3000  |  Production: https://compound-360.com
PUBLIC_BACKEND_URL=
# Optional aliases (first non-empty wins): PAYMENT_BACKEND_URL, CHAPA_BACKEND_URL, API_PUBLIC_URL

# Coturn TURN Server Configuration
COTURN_SERVER=coturn_ip_addr
COTURN_PORT=coturn_port_default is 3478
COTURN_USERNAME=coturn username
COTURN_PASSWORD=coturn pass
COTURN_REALM=coturn realm
